#!/bin/bash

echo "============================================================"
echo "DocManager 打包脚本"
echo "============================================================"
echo

echo "检查环境..."
python3 --version
if [ $? -ne 0 ]; then
    echo "错误: 未找到 Python"
    exit 1
fi

echo
echo "检查依赖..."
pip3 show pyinstaller > /dev/null 2>&1
if [ $? -ne 0 ]; then
    echo "安装 PyInstaller..."
    pip3 install pyinstaller
fi

echo
echo "开始打包..."
python3 build_exe.py

echo
echo "完成!"