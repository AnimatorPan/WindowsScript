@echo off
chcp 65001 >nul
echo ============================================================
echo DocManager 打包脚本
echo ============================================================
echo.

echo 检查环境...
python --version
if errorlevel 1 (
    echo 错误: 未找到 Python
    pause
    exit /b 1
)

echo.
echo 检查依赖...
pip show pyinstaller >nul 2>&1
if errorlevel 1 (
    echo 安装 PyInstaller...
    pip install pyinstaller
)

echo.
echo 开始打包...
python build_exe.py

echo.
echo 完成!
pause